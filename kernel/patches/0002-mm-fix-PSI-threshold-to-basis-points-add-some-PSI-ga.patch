From b1d918de97cacfc8c3ba4511705a961b33dc7fcc Mon Sep 17 00:00:00 2001
From: huziaf <huzaifaphantompak@gmail.com>
Date: Tue, 19 May 2026 14:37:56 -0400
Subject: [PATCH 2/2] mm: fix PSI threshold to basis points; add some-PSI gate
 and activation counter

LOAD_INT >= 25 required 25% full stall; benchmarks peaked at ~0.14%.
Use fixed-point compare at 10 bps (0.10%), trigger on mem some or full.
Expose activation count via debugfs pressure_pause_activations.

Co-authored-by: Cursor <cursoragent@cursor.com>
---
 include/linux/psi.h |  2 ++
 kernel/sched/psi.c  | 15 +++++++++++++--
 mm/vmscan.c         | 33 ++++++++++++++++++++++++++++++---
 3 files changed, 45 insertions(+), 5 deletions(-)

diff --git a/include/linux/psi.h b/include/linux/psi.h
index ca0094e8b..ec9491baa 100644
--- a/include/linux/psi.h
+++ b/include/linux/psi.h
@@ -23,6 +23,7 @@ void psi_memstall_enter(unsigned long *flags);
 void psi_memstall_leave(unsigned long *flags);
 
 unsigned long psi_mem_full_avg10(void);
+unsigned long psi_mem_some_avg10(void);
 
 int psi_show(struct seq_file *s, struct psi_group *group, enum psi_res res);
 struct psi_trigger *psi_trigger_create(struct psi_group *group, char *buf,
@@ -52,6 +53,7 @@ static inline void psi_init(void) {}
 static inline void psi_memstall_enter(unsigned long *flags) {}
 static inline void psi_memstall_leave(unsigned long *flags) {}
 static inline unsigned long psi_mem_full_avg10(void) { return 0; }
+static inline unsigned long psi_mem_some_avg10(void) { return 0; }
 
 #ifdef CONFIG_CGROUPS
 static inline int psi_cgroup_alloc(struct cgroup *cgrp)
diff --git a/kernel/sched/psi.c b/kernel/sched/psi.c
index 4cf799f68..37fa0ef7d 100644
--- a/kernel/sched/psi.c
+++ b/kernel/sched/psi.c
@@ -1222,7 +1222,7 @@ void psi_cgroup_restart(struct psi_group *group)
 }
 #endif /* CONFIG_CGROUPS */
 
-unsigned long psi_mem_full_avg10(void)
+static unsigned long psi_mem_avg10(enum psi_states state)
 {
 	unsigned long avg;
 	u64 now;
@@ -1235,13 +1235,24 @@ unsigned long psi_mem_full_avg10(void)
 	collect_percpu_times(&psi_system, PSI_AVGS, NULL);
 	if (now >= psi_system.avg_next_update)
 		psi_system.avg_next_update = update_averages(&psi_system, now);
-	avg = psi_system.avg[PSI_MEM_FULL][0];
+	avg = psi_system.avg[state][0];
 	mutex_unlock(&psi_system.avgs_lock);
 
 	return avg;
 }
+
+unsigned long psi_mem_full_avg10(void)
+{
+	return psi_mem_avg10(PSI_MEM_FULL);
+}
 EXPORT_SYMBOL_GPL(psi_mem_full_avg10);
 
+unsigned long psi_mem_some_avg10(void)
+{
+	return psi_mem_avg10(PSI_MEM_SOME);
+}
+EXPORT_SYMBOL_GPL(psi_mem_some_avg10);
+
 int psi_show(struct seq_file *m, struct psi_group *group, enum psi_res res)
 {
 	bool only_full = false;
diff --git a/mm/vmscan.c b/mm/vmscan.c
index 679e08abe..8f598dcf7 100644
--- a/mm/vmscan.c
+++ b/mm/vmscan.c
@@ -6171,9 +6171,33 @@ static void snapshot_refaults(struct mem_cgroup *target_memcg, pg_data_t *pgdat)
 }
 
 #ifdef CONFIG_PSI
-#define PSI_FULL_THRESHOLD_PCT	25
+/*
+ * PSI avg10 threshold in basis points (100 bps = 1.00% as shown in
+ * /proc/pressure/memory).  Old LOAD_INT >= 25 required 25% full stall and
+ * never fired when peaks were ~0.14%.
+ */
+#define PSI_MEM_THRESHOLD_BPS	10
+#define PSI_MEM_THRESHOLD_FIXED \
+	((unsigned long)FIXED_1 * PSI_MEM_THRESHOLD_BPS / 10000)
 #define PRESSURE_PAUSE_MAX_MS	20
 
+static atomic64_t pressure_pause_activations;
+
+static int pressure_pause_count_show(struct seq_file *m, void *p)
+{
+	seq_printf(m, "%lld\n", atomic64_read(&pressure_pause_activations));
+	return 0;
+}
+DEFINE_SHOW_ATTRIBUTE(pressure_pause_count);
+
+static int __init pressure_pause_debugfs_init(void)
+{
+	debugfs_create_file("pressure_pause_activations", 0444, NULL, NULL,
+			    &pressure_pause_count_fops);
+	return 0;
+}
+late_initcall(pressure_pause_debugfs_init);
+
 static bool pressure_pause_zones_ok(struct zonelist *zonelist,
 				    struct scan_control *sc)
 {
@@ -6228,14 +6252,16 @@ static void pressure_pause_wake_kswapd(struct zonelist *zonelist,
 static void pressure_pause_maybe(struct zonelist *zonelist,
 				 struct scan_control *sc)
 {
-	unsigned long psi_full;
+	unsigned long psi_full, psi_some;
 	unsigned long deadline;
 
 	if (cgroup_reclaim(sc))
 		return;
 
 	psi_full = psi_mem_full_avg10();
-	if (LOAD_INT(psi_full) < PSI_FULL_THRESHOLD_PCT)
+	psi_some = psi_mem_some_avg10();
+	if (psi_full < PSI_MEM_THRESHOLD_FIXED &&
+	    psi_some < PSI_MEM_THRESHOLD_FIXED)
 		return;
 
 	if (!pressure_pause_has_reclaimable(zonelist, sc))
@@ -6245,6 +6271,7 @@ static void pressure_pause_maybe(struct zonelist *zonelist,
 		return;
 
 	pressure_pause_wake_kswapd(zonelist, sc);
+	atomic64_inc(&pressure_pause_activations);
 
 	deadline = jiffies + msecs_to_jiffies(PRESSURE_PAUSE_MAX_MS);
 	while (time_before(jiffies, deadline)) {
-- 
2.34.1

