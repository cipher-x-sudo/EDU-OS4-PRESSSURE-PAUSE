+/* True if any managed zone in the zonelist still needs reclaim (not at min). */
+static bool pressure_pause_under_pressure(struct zonelist *zonelist,
+					  struct scan_control *sc)
+{
+	struct zoneref *z;
+	struct zone *zone;
+	bool any = false;
+
+	for_each_zone_zonelist_nodemask(zone, z, zonelist, sc->reclaim_idx,
+					sc->nodemask) {
+		if (!managed_zone(zone))
+			continue;
+		any = true;
+		if (!zone_watermark_ok(zone, sc->order, min_wmark_pages(zone),
+				       sc->reclaim_idx, 0))
+			return true;
+	}
+	return false;
+}
+
+/* True if any zone has reached min watermarks (progress / relief). */
+static bool pressure_pause_any_zone_ok(struct zonelist *zonelist,
+				       struct scan_control *sc)
+{
+	struct zoneref *z;
+	struct zone *zone;
+
+	for_each_zone_zonelist_nodemask(zone, z, zonelist, sc->reclaim_idx,
+					sc->nodemask) {
+		if (!managed_zone(zone))
+			continue;
+		if (zone_watermark_ok(zone, sc->order, min_wmark_pages(zone),
+				      sc->reclaim_idx, 0))
+			return true;
+	}
+	return false;
+}
+
+static bool pressure_pause_has_reclaimable(struct zonelist *zonelist,
+					   struct scan_control *sc)
+{
+	struct zoneref *z;
+	struct zone *zone;
+
+	for_each_zone_zonelist_nodemask(zone, z, zonelist, sc->reclaim_idx,
+					sc->nodemask) {
+		if (!managed_zone(zone))
+			continue;
+		if (zone_reclaimable_pages(zone))
+			return true;
+	}
+	return false;
+}
+
+static void pressure_pause_wake_kswapd(struct zonelist *zonelist,
+				       struct scan_control *sc)
+{
+	struct zoneref *z;
+	struct zone *zone;
+
+	for_each_zone_zonelist_nodemask(zone, z, zonelist, sc->reclaim_idx,
+					sc->nodemask) {
+		if (!managed_zone(zone))
+			continue;
+		wakeup_kswapd(zone, sc->gfp_mask, sc->order, sc->reclaim_idx);
+	}
+}
