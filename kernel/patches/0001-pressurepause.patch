+static atomic64_t pressure_pause_activations;
+static atomic64_t pressure_pause_entered;
+static atomic64_t pressure_pause_skip_psi;
+static atomic64_t pressure_pause_skip_zones_ok;
+static atomic64_t pressure_pause_skip_no_reclaimable;
+static atomic64_t pressure_pause_skip_cgroup;
+static atomic64_t pressure_pause_peak_psi_some;
+static atomic64_t pressure_pause_peak_psi_full;
+
+static void pressure_pause_note_psi(unsigned long psi_some, unsigned long psi_full)
+{
+	unsigned long peak;
+
+	peak = atomic64_read(&pressure_pause_peak_psi_some);
+	if (psi_some > peak)
+		atomic64_set(&pressure_pause_peak_psi_some, psi_some);
+
+	peak = atomic64_read(&pressure_pause_peak_psi_full);
+	if (psi_full > peak)
+		atomic64_set(&pressure_pause_peak_psi_full, psi_full);
+}
+
