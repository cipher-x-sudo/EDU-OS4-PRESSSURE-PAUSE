+#ifdef CONFIG_PSI
+/*
+ * PSI avg10 threshold in basis points (100 bps = 1.00% as shown in
+ * /proc/pressure/memory).  Old LOAD_INT(psi) >= 25 compared the integer
+ * part of the fixed-point average to 25, i.e. 25.00% stall — not 0.25%.
+ * Benchmarks peaked near full avg10=0.18 (0.18%) and never crossed that gate.
+ */
+#define PSI_MEM_THRESHOLD_BPS	1
+#define PRESSURE_PAUSE_MAX_MS	20
+
+/* Same fixed-point units as psi_mem_*_avg10() / /proc/pressure/memory avg10. */
+static inline unsigned long psi_mem_threshold_fixed(unsigned int bps)
+{
+	return (unsigned long)FIXED_1 * bps / 10000;
+}
+
+static inline bool psi_mem_avg10_exceeds_bps(unsigned long avg, unsigned int bps)
+{
+	return avg >= psi_mem_threshold_fixed(bps);
+}
