+	seq_printf(m, "entered %lld\n", atomic64_read(&pressure_pause_entered));
+	seq_printf(m, "skip_psi_low %lld\n", atomic64_read(&pressure_pause_skip_psi));
+	seq_printf(m, "skip_zones_ok %lld\n", atomic64_read(&pressure_pause_skip_zones_ok));
+	seq_printf(m, "skip_no_reclaimable %lld\n",
+		   atomic64_read(&pressure_pause_skip_no_reclaimable));
+	seq_printf(m, "skip_cgroup %lld\n", atomic64_read(&pressure_pause_skip_cgroup));
+	seq_printf(m, "peak_psi_some_avg10 %llu.%02llu\n",
+		   LOAD_INT(atomic64_read(&pressure_pause_peak_psi_some)),
+		   LOAD_FRAC(atomic64_read(&pressure_pause_peak_psi_some)));
+	seq_printf(m, "peak_psi_full_avg10 %llu.%02llu\n",
+		   LOAD_INT(atomic64_read(&pressure_pause_peak_psi_full)),
+		   LOAD_FRAC(atomic64_read(&pressure_pause_peak_psi_full)));
+	return 0;
+}
